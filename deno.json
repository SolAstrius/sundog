{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "serve": "deno run --allow-net --allow-read server/main.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "exclude": ["dist/", "node_modules/"]
  },
  "lint": {
    "exclude": ["dist/", "node_modules/"]
  }
}
