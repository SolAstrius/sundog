# Sundog configuration (Vite .env — only VITE_-prefixed vars reach the client bundle).
# These are non-secret (public OAuth client, server URL): this file is committed as the default
# config. Override locally in .env.local (gitignored), e.g. to point at another JMAP server.

VITE_SERVER_BASE=https://mail.astrius.ink

# OAuth public client registered against Stalwart via RFC 7591 dynamic registration (2026-07-08).
# Redirect URIs: https://cal.astrius.ink/auth/callback and http://127.0.0.1/auth/callback
# (loopback — any port matches per RFC 8252 §7.3).
VITE_OAUTH_CLIENT_ID=swc1.aP-D406RSA2374LZhed5bCyVHV5el0pZYkRwkEgwfHKSLIkvhJbveFsDSX2pojacGQ8FeDHKhUdRUdLHOW2cPOoyKRdLnsH3oCYb86pLPZm6WlKBnK0sw2z1tpmXEW91HfM2mKjTeXw902k

# Space-separated OAuth scopes; offline_access is required for refresh tokens.
VITE_OAUTH_SCOPES=offline_access urn:ietf:params:oauth:scope:mail urn:ietf:params:oauth:scope:contacts urn:ietf:params:oauth:scope:calendars

# How often the state poller checks for server-side changes (ms).
VITE_POLL_INTERVAL_MS=30000
